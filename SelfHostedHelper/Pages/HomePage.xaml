<Page x:Class="SelfHostedHelper.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:viewModels="clr-namespace:SelfHostedHelper.ViewModels"
      xmlns:utils="clr-namespace:SelfHostedHelper.Classes.Utils"
      xmlns:controls="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
      d:DesignHeight="800" d:DesignWidth="600"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="HomePage"
      d:DataContext="{d:DesignInstance viewModels:UserSettings}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Page.Resources>
        <utils:BoolToEnabledDisabledConverter x:Key="BoolToEnabledDisabledConverter" />
    </Page.Resources>

    <StackPanel MaxWidth="1000" Margin="16">
        <!-- Header -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
            <ui:SymbolIcon Symbol="Rocket24" FontSize="36" Margin="0,0,12,0" />
            <TextBlock Text="Taskbar Launcher" FontSize="24" FontWeight="Medium" VerticalAlignment="Center" />
            <TextBlock x:Name="VersionTextBlock" FontSize="14" FontWeight="Regular" VerticalAlignment="Bottom" Margin="10" Opacity="0.5" />
        </StackPanel>

        <TextBlock Text="Home" FontSize="24" FontWeight="SemiBold" Margin="0,24,0,12" />

        <!-- Dashboard cards -->
        <TextBlock Text="Dashboard" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6" />
        <Grid Margin="-4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:CardAction Grid.Column="0" Margin="4" Padding="12,20" IsChevronVisible="True" Click="LauncherItems_Click">
                <ui:CardAction.Icon>
                    <ui:SymbolIcon Symbol="AppsList24" FontSize="30" Filled="False" />
                </ui:CardAction.Icon>
                <StackPanel>
                    <ui:TextBlock FontWeight="Medium" Text="Launcher Items" />
                    <ui:TextBlock Appearance="Secondary" Text="Manage your shortcuts" />
                </StackPanel>
            </ui:CardAction>

            <ui:CardAction Grid.Column="1" Margin="4" Padding="12,20" IsChevronVisible="True" Click="SyncSettings_Click">
                <ui:CardAction.Icon>
                    <ui:SymbolIcon Symbol="CloudSync24" FontSize="30" Filled="False" />
                </ui:CardAction.Icon>
                <StackPanel>
                    <ui:TextBlock FontWeight="Medium" Text="Cloud Sync" />
                    <ui:TextBlock Appearance="Secondary" Text="SSH/SFTP sync" />
                </StackPanel>
            </ui:CardAction>
        </Grid>

        <!-- Widget status -->
        <TextBlock Text="Taskbar Widget" FontSize="14" FontWeight="SemiBold" Margin="0,24,0,6" />
        <ui:CardControl Icon="{ui:SymbolIcon TextboxAlignBottom24}" Margin="0,0,0,3">
            <ui:CardControl.Header>
                <StackPanel>
                    <TextBlock Text="Enable Taskbar Widget" FontSize="14" FontWeight="Regular" />
                    <TextBlock Text="Show the launcher widget on the taskbar" FontSize="12" Opacity="0.5" />
                </StackPanel>
            </ui:CardControl.Header>
            <controls:ToggleSwitch IsChecked="{Binding TaskbarWidgetEnabled, Mode=TwoWay}" />
        </ui:CardControl>
    </StackPanel>
</Page>
