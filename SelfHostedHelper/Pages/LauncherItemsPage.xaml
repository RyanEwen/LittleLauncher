<Page x:Class="SelfHostedHelper.Pages.LauncherItemsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:pages="using:SelfHostedHelper.Pages">

    <Page.Resources>
        <!-- Template for regular launcher items -->
        <DataTemplate x:Key="LauncherItemTemplate">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,2">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" FontSize="20" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="14"/>
                        <TextBlock Text="{Binding Path}" FontSize="12" Opacity="0.5" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                        <Button Content="Edit" Click="EditItem_Click" Tag="{Binding}"/>
                        <Button Content="Remove" Click="RemoveItem_Click" Tag="{Binding}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Template for category headings -->
        <DataTemplate x:Key="CategoryItemTemplate">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,2">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE8FD;" FontSize="20" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                        <Button Content="Edit" Click="EditItem_Click" Tag="{Binding}"/>
                        <Button Content="Remove" Click="RemoveItem_Click" Tag="{Binding}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <pages:LauncherItemTemplateSelector x:Key="ItemTemplateSelector"
            LauncherItemTemplate="{StaticResource LauncherItemTemplate}"
            CategoryItemTemplate="{StaticResource CategoryItemTemplate}"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
        <StackPanel MaxWidth="1000" Margin="16">
            <TextBlock Text="Launcher Items" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBlock Text="Add, edit, or remove apps and websites from your taskbar launcher. Drag items to reorder."
                       FontSize="14" Opacity="0.6" Margin="0,0,0,16"/>

            <ListView x:Name="ItemsList" Margin="0,0,0,8"
                      CanReorderItems="True"
                      AllowDrop="True"
                      SelectionMode="None"
                      ItemTemplateSelector="{StaticResource ItemTemplateSelector}"
                      DragItemsCompleted="ItemsList_DragItemsCompleted">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" Spacing="8">
                <Button Style="{ThemeResource AccentButtonStyle}" Click="ShowAddDialog_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="14"/>
                        <TextBlock Text="Add Item"/>
                    </StackPanel>
                </Button>
                <Button Click="ShowAddCategoryDialog_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8FD;" FontSize="14"/>
                        <TextBlock Text="Add Category"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Page>