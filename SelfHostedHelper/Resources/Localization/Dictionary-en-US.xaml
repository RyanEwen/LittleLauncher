<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:System="clr-namespace:System;assembly=mscorlib">

    <!-- General -->
    <System:String x:Key="TitleText">Taskbar Launcher Settings</System:String>
    <System:String x:Key="Enabled">Enabled</System:String>
    <System:String x:Key="Disabled">Disabled</System:String>

    <!-- Home / Dashboard -->
    <System:String x:Key="HomeTitle">Home</System:String>
    <System:String x:Key="HomeDashboardTitle">Dashboard</System:String>

    <!-- Launcher Items -->
    <System:String x:Key="LauncherItemsTitle">Launcher Items</System:String>
    <System:String x:Key="LauncherItemsDescription">Add applications or websites that appear in your taskbar widget for quick access.</System:String>

    <!-- Cloud Sync -->
    <System:String x:Key="CloudSyncTitle">Cloud Sync</System:String>
    <System:String x:Key="CloudSyncDescription">Synchronise your settings to a remote server using SSH/SFTP.</System:String>

    <!-- Taskbar Widget -->
    <System:String x:Key="TaskbarWidgetEnabledTitle">Enable Taskbar Widget</System:String>
    <System:String x:Key="TaskbarWidgetEnabledDescription">Show a compact launcher widget on the taskbar</System:String>
    <System:String x:Key="TaskbarWidgetSelectedMonitorTitle">Widget Target Display</System:String>
    <System:String x:Key="TaskbarWidgetPosition">Widget Position</System:String>
    <System:String x:Key="TaskbarWidgetPaddingSettingsTitle">Widget Padding Settings</System:String>
    <System:String x:Key="TaskbarWidgetPaddingSettingsDescription">Adjust the padding around the widget to fit your taskbar style</System:String>
    <System:String x:Key="TaskbarWidgetPaddingTitle">Automatic Padding for Windows Widgets button</System:String>
    <System:String x:Key="TaskbarWidgetPaddingDescription">Turn this feature on if you have Windows Widgets enabled</System:String>
    <System:String x:Key="TaskbarWidgetManualPaddingTitle">Custom Padding</System:String>
    <System:String x:Key="TaskbarWidgetManualPaddingDescription">Add extra padding (default: 0px)</System:String>
    <System:String x:Key="TaskbarWidgetVisualIssuesWarning">Configure the options below if you experience visual issues.</System:String>
    <System:String x:Key="PositionLeft">Left</System:String>
    <System:String x:Key="PositionRight">Right</System:String>
    <System:String x:Key="PixelsUnit">px</System:String>

    <!-- System Settings -->
    <System:String x:Key="SystemSettingsTitle">Settings</System:String>
    <System:String x:Key="AppearanceBehaviorSectionTitle">Appearance &amp; behaviour</System:String>
    <System:String x:Key="AppThemeTitle">App Theme</System:String>
    <System:String x:Key="AppThemeDefault"> Windows Default</System:String>
    <System:String x:Key="AppThemeLight"> Light</System:String>
    <System:String x:Key="AppThemeDark"> Dark</System:String>
    <System:String x:Key="LaunchOnStartupTitle">Launch on Startup</System:String>
    <System:String x:Key="LaunchOnStartupDescription">Start minimized to tray when you log in to Windows</System:String>
    <System:String x:Key="StartupAppsHyperlinkText">Startup Apps</System:String>
    <System:String x:Key="StartupAppsSettingsInfo">If this setting does not work as expected, check</System:String>
    <System:String x:Key="SystemConfigure">Configure</System:String>

    <!-- Tray Icon -->
    <System:String x:Key="TrayIconSectionTitle">Tray Icon</System:String>
    <System:String x:Key="Win11TrayIconTitle">Windows 11-like Tray Icon</System:String>
    <System:String x:Key="Win11TrayIconDescription">Use a tray icon that matches Windows 11 (toggle to refresh theme)</System:String>
    <System:String x:Key="HideTrayIconTitle">Hide Tray Icon Completely</System:String>
    <System:String x:Key="HideTrayIconDescription">Access settings from launching the program twice</System:String>
    <System:String x:Key="TrayIcon_SettingsOption">Settings</System:String>
    <System:String x:Key="TrayIcon_QuitOption">Quit</System:String>

    <!-- Back up and restore -->
    <System:String x:Key="BackupRestoreSectionTitle">Back up &amp; restore</System:String>
    <System:String x:Key="BackupRestoreCardTitle">Back up and restore your settings</System:String>
    <System:String x:Key="ExportSettings">Export Settings</System:String>
    <System:String x:Key="ImportSettings">Import Settings</System:String>
    <System:String x:Key="ExportSuccessful">Export Successful</System:String>
    <System:String x:Key="ExportFailed">Export Failed</System:String>
    <System:String x:Key="ImportSuccessful">Import Successful</System:String>
    <System:String x:Key="ImportFailed">Import Failed</System:String>
    <System:String x:Key="SettingsExportedSuccessfully">Settings exported successfully!</System:String>
    <System:String x:Key="FailedToExportSettings">Failed to export settings. Check the logs for details.</System:String>
    <System:String x:Key="SettingsImportedSuccessfully">Settings imported successfully! The application will now restart to apply changes.</System:String>
    <System:String x:Key="ImportSettingsWarning">This will replace all your current settings. Continue?</System:String>
    <System:String x:Key="FailedToImportSettings">Failed to import settings. Check the logs for details.</System:String>

    <!-- About -->
    <System:String x:Key="AboutTitle">About</System:String>
    <System:String x:Key="GitHubRepoLink">GitHub Repository</System:String>
    <System:String x:Key="CloseButton">Close</System:String>
</ResourceDictionary>
