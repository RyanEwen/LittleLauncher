<Window x:Class="SelfHostedHelper.Windows.TaskbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SelfHostedHelper.Controls"
        Title="TaskbarWindow" Height="40" Width="400"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextFormattingMode="Ideal"
        FontFamily="Segoe UI Variable"
        Loaded="Window_Loaded" Visibility="Collapsed" >
    <!--
        TaskbarWindow.xaml
        ==================
        This window is reparented into the Windows taskbar (Shell_TrayWnd) using
        SetParent P/Invoke. It switches from WS_POPUP to WS_CHILD window style
        so Windows treats it as a taskbar child.

        The window is sized to exactly the launcher area and positioned at the
        calculated offset within the taskbar, so it doesn't overlay native icons.

        The Canvas hosts the TaskbarLauncherControl which renders the row of
        launcher shortcut buttons.
    -->
    <!-- Alpha=1 (not 0) so the layered window is hit-testable for mouse events -->
    <Canvas Name="WidgetCanvas" Background="#01000000">
        <controls:TaskbarLauncherControl x:Name="Launcher" />
    </Canvas>
</Window>
