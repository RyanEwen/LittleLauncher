<Window x:Class="SelfHostedHelper.Windows.FlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="Manual"
        Deactivated="Window_Deactivated"
        KeyDown="Window_KeyDown"
        SizeToContent="WidthAndHeight"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextFormattingMode="Ideal"
        FontFamily="Segoe UI Variable">
    <Border Name="RootBorder" CornerRadius="8" Padding="4" Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.4" ShadowDepth="2" Color="Black"/>
        </Border.Effect>
        <StackPanel Name="ItemsPanel" MinWidth="220" />
    </Border>
</Window>
