<Window x:Class="SelfHostedHelper.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Height="0" Width="0"
    WindowStyle="None"
    ShowInTaskbar="False"
    ResizeMode="NoResize"
    Loaded="Window_Loaded"
    Title="TaskbarLauncher Host">
    <!--
        MainWindow.xaml
        ===============
        This is the invisible host window. It:
          1. Creates the singleton mutex (prevents multiple instances).
          2. Hosts the tray icon with context menu.
          3. Creates and owns the TaskbarWindow (the widget parented into the taskbar).

        The window itself is never shown — it sits outside the visible screen area.
        All visual interaction is through the taskbar widget and the settings window.
    -->
    <Grid>
        <!-- System tray icon -->
        <tray:NotifyIcon
            x:Name="nIcon"
            LeftClick="nIcon_LeftClick" FocusOnLeftClick="False"
            MenuOnRightClick="True"
            TooltipText="Taskbar Launcher"
            Icon="/Resources/SelfHostedHelper.ico"
            Visibility="Visible">
            <tray:NotifyIcon.Menu>
                <ContextMenu>
                    <ui:MenuItem Header="Settings" Click="OpenSettings_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Settings20"/>
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                    <Separator />
                    <ui:MenuItem Header="Exit" Click="Exit_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="ArrowExit20"/>
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>
    </Grid>
</Window>
