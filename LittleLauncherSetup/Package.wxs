<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <!-- Version is injected by the build: -d ProductVersion=1.0.0.0 -->
  <?ifndef ProductVersion ?>
    <?define ProductVersion = "1.3.0.0" ?>
  <?endif ?>

  <Package Name="Little Launcher"
           Manufacturer="RyanEwen"
           Version="$(ProductVersion)"
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
           Scope="perUser"
           InstallerVersion="500">

    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version of Little Launcher is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Install to LocalAppData\Little Launcher (per-user, no elevation needed) -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="Little Launcher" />
    </StandardDirectory>

    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <!-- Harvest the entire build output directory, excluding debug symbols -->
      <Files Include="$(BuildOutputPath)\**">
        <Exclude Files="$(BuildOutputPath)\**\*.pdb" />
      </Files>
    </ComponentGroup>

    <!-- Initial Start Menu shortcut so users can find the app after install.
         On first launch the app overwrites it with the user's chosen icon. -->
    <ComponentGroup Id="Shortcuts" Directory="ProgramMenuFolder">
      <Component Id="StartMenuShortcut">
        <Shortcut Id="StartMenuLauncher"
                  Name="Little Launcher"
                  Target="[INSTALLFOLDER]LittleLauncher.exe"
                  Arguments="--settings"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="AppIcon" />
        <RegistryValue Root="HKCU"
                       Key="Software\LittleLauncher"
                       Name="StartMenuShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Feature Id="Main" Title="Little Launcher" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentGroupRef Id="Shortcuts" />
    </Feature>

    <Icon Id="AppIcon" SourceFile="$(BuildOutputPath)\Resources\LittleLauncher.ico" />

    <!-- Launch the app after install or upgrade (not on uninstall or repair) -->
    <CustomAction Id="LaunchApp"
                  Directory="INSTALLFOLDER"
                  ExeCommand="[INSTALLFOLDER]LittleLauncher.exe"
                  Impersonate="yes"
                  Return="asyncNoWait" />
    <InstallExecuteSequence>
      <Custom Action="LaunchApp" After="InstallFinalize" Condition="NOT REMOVE" />
    </InstallExecuteSequence>

  </Package>
</Wix>
