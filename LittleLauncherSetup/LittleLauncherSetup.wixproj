<Project Sdk="WixToolset.Sdk/5.0.2">
  <PropertyGroup>
    <OutputType>Package</OutputType>
    <InstallerPlatform>$(Platform)</InstallerPlatform>
  </PropertyGroup>
  <PropertyGroup>
    <DefineConstants>BuildOutputPath=$(BuildOutputPath);ProductVersion=$(Version).0</DefineConstants>
  </PropertyGroup>
</Project>
