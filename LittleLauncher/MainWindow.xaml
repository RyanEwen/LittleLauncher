<Window
    x:Class="LittleLauncher.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="LittleLauncher Host">
    <!--
        MainWindow.xaml (WinUI 3)
        =========================
        This is the invisible host window. It:
          1. Creates the singleton mutex (prevents multiple instances).
          2. Manages the system tray icon (H.NotifyIcon).

        The window itself is never shown — it sits outside the visible screen area.
        All visual interaction is through the tray icon flyout and the settings window.
    -->
    <Grid />
</Window>